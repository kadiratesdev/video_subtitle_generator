{
  "name": "video-subtitle-generator-ui",
  "private": true,
  "scripts": {
    "copy:vendor": "node -e \"const fs=require('fs');fs.mkdirSync('web/static/vendor',{recursive:true});fs.copyFileSync('node_modules/preline/dist/preline.js','web/static/vendor/preline.js');\"",
    "build:css": "tailwindcss -i web/static/src/input.css -o web/static/tailwind.css --minify",
    "build:ui": "npm run build:css && npm run copy:vendor"
  },
  "dependencies": {
    "preline": "^4.2.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "@tailwindcss/forms": "^0.5.10",
    "tailwindcss": "^4.1.11"
  }
}

# Groq API anahtarı (https://console.groq.com)
GROQ_API_KEY=

# Uzak video kaynağı (sonunda / olmalı)
VIDEO_BASE_URL=https://example.com/videos/
# remote = uzak URL listesi, local = yerel klasör
VIDEO_SOURCE=remote
# Yerel mod için klasör (arayüzden de değiştirilebilir)
LOCAL_VIDEO_DIR=
# Kaynak dil: es (İspanyolca) veya en (İngilizce)
SOURCE_LANG=es

# Yerel klasörler (göreli yollar proje/exe dizinine göre çözülür)
VIDEOS_DIR=videos
OUTPUT_DIR=output

# Groq modelleri
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_LINES_PER_CALL=15

# Web arayüzü
WEB_HOST=127.0.0.1
WEB_PORT=8765

# 1 yaparsanız altyazı videoya gömülür (daha yavaş, daha fazla disk)
EMBED_SUBTITLES=0

# Yerel Whisper kullanmak için (CUDA gerekir)
USE_LOCAL_WHISPER=0
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
